subject_domain_of_cleaning_reagents <- sc_node_struct;;
subject_domain_of_cleaning_reagents => nrel_main_idtf: [Предметная область реагентов для очистки] (*<- lang_ru;;*);;
concept_cleaning_reagents <- sc_node_class;
              => nrel_main_idtf: [реагенты для очистки](*<- lang_ru;;*);;

subject_domain_of_cleaning_reagents
                                => nrel_partition:
                                                  concept_aluminum_salts_coagulants;
                                                  concept_iron_salts_coagulants;
                                                  concept_lime_CaO;
                                                  concept_anionic_flocculants;
                                                  concept_cationic_flocculants;;







concept_aluminum_salts_coagulants <- sc_node_class;
    => nrel_main_idtf: [соли алюминия (коагулянты)](*<- lang_ru;;*);
    => sc_link_content: [соединения алюминия, такие как сульфат алюминия (Al₂(SO₄)₃) и хлорид алюминия (AlCl₃), которые используются для осаждения взвешенных частиц и очистки воды в процессах коагуляции и флокуляции];;
concept_aluminum_salts_coagulants -> rrel_maximum_studied_object_class: concept_cleaning_reagents;;
concept_aluminum_salts_coagulants => nrel_partition:
    concept_aluminum_sulfate;
    concept_aluminum_chloride;
    concept_aluminum_polycarboxylate;;

concept_aluminum_salts_coagulants => nrel_application:
    concept_drinking_wastewater_treatment;
    concept_water_treatment_plants;
    concept_industrial_water_preparation;;

concept_aluminum_salts_coagulants => nrel_technical_parameter:
    rrel_coagulant_concentration;
    rrel_ph_efficiency;;

concept_aluminum_salts_coagulants => nrel_operation_principle:
    concept_coagulation_process;
    concept_neutralization;;

concept_aluminum_salts_coagulants => nrel_component:
    concept_aluminum_sulfate_component;
    concept_aluminum_chloride_component;
    concept_aluminum_polycarboxylate_component;;

concept_aluminum_salts_coagulants => nrel_type:
    concept_aluminum_sulfate_type;
    concept_aluminum_chloride_type;
    concept_organic_coagulants_type;;



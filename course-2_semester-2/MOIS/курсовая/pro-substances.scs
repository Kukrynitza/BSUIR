    rrel_treatment_efficiency;;

concept_ammonium_ion -> nrel_operation_principle:
    concept_biological_oxidation;
    concept_chemical_removal;;

concept_ammonium_ion -> nrel_component:
    concept_ammonium;
    concept_nitrifying_microorganisms;
    concept_chemical_reagents;;

concept_ammonium_ion -> nrel_type:
    concept_ammonium_in_primary_effluent;
    concept_ammonium_in_secondary_sludge;;



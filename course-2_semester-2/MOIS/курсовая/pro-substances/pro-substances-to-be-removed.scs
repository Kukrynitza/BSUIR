concept_mineral_oil_emulsions <- sc_node_class;
    => nrel_main_idtf: [эмульсии на основе минеральных масел](*<- lang_ru;;*);;

concept_vegetable_oil_emulsions <- sc_node_class;
    => nrel_main_idtf: [эмульсии на основе растительных масел](*<- lang_ru;;*);;





concept_oil_and_grease_contaminants <- sc_node_class;
    => nrel_main_idtf: [жиро- и нефтесодержащие примеси](*<- lang_ru;;*);
    => sc_link_content: [загрязнители, содержащие масла и нефтепродукты, которые могут попасть в сточные воды в результате производственных процессов, бытовых выбросов или утечек из транспортных средств и оборудования];;
concept_oil_and_grease_contaminants -> rrel_maximum_studied_object_class: concept_substances_to_be_removed;;
concept_oil_and_grease_contaminants => nrel_partition:
    concept_animal_oils_fats;
    concept_vegetable_oils_fats;
    concept_petroleum_products;;

concept_oil_and_grease_contaminants => nrel_application:
    concept_wastewater_treatment;
    concept_petroleum_chemical_industry;
    concept_automotive_industry;;

concept_oil_and_grease_contaminants => nrel_technical_parameter:
    rrel_oil_and_fat_content;
    rrel_contaminant_type;;

concept_oil_and_grease_contaminants => nrel_operation_principle:
    concept_toxicity;
    concept_removal_processes;;

concept_oil_and_grease_contaminants => nrel_component:

concept_chloride_ion <- sc_node_class;
    => nrel_main_idtf: [хлорид-ион](*<- lang_ru;;*);
    => sc_link_content: [негативно заряженный ион хлора, образующийся при растворении хлористых соединений, таких как хлорид натрия (NaCl), в воде.];;
concept_chloride_ion -> rrel_maximum_studied_object_class: concept_major_pollutants;;
concept_chloride_ion => nrel_partition:
    concept_dissolved_chloride;
    concept_sediment_bound_chloride;;

concept_chloride_ion => nrel_application:
    concept_water_quality_monitoring;
    concept_salt_pollution_control;
    concept_water_characteristics_in_treatment;;

concept_chloride_ion => nrel_technical_parameter:
    rrel_chloride_ion_concentration;
    rrel_corrosion_and_process_impact;;

concept_chloride_ion => nrel_operation_principle:
    concept_no_biological_involvement;
    concept_source_in_wastewater;;

concept_chloride_ion => nrel_component:
    concept_chloride_ion;
    concept_chloride_compounds;;

concept_chloride_ion => nrel_type:
    concept_dissolved_chloride_type;
    concept_sediment_bound_chloride_type;;


concept_dissolved_chloride <- sc_node_class;
    => nrel_main_idtf: [хлорид в растворённой форме (Cl⁻)](*<- lang_ru;;*);;

concept_sediment_bound_chloride <- sc_node_class;
    => nrel_main_idtf: [хлорид в осадках](*<- lang_ru;;*);;

concept_water_quality_monitoring <- sc_node_class;
    => nrel_main_idtf: [мониторинг качества воды и сточных вод](*<- lang_ru;;*);;

concept_salt_pollution_control <- sc_node_class;
    => nrel_main_idtf: [контроль солевого загрязнения воды](*<- lang_ru;;*);;

concept_water_characteristics_in_treatment <- sc_node_class;

concept_organic_pollutants <- sc_node_class;
    => nrel_main_idtf: [органические загрязнители (углеводы, белки, жиры)](*<- lang_ru;;*);;

concept_aerobic_microorganisms <- sc_node_class;
    => nrel_main_idtf: [аэробные бактерии и микроорганизмы](*<- lang_ru;;*);;

concept_dissolved_oxygen <- sc_node_class;

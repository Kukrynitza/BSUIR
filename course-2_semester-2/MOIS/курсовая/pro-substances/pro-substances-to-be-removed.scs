    => nrel_main_idtf: [очистка сточных вод (удаление нефтяных загрязнителей)](*<- lang_ru;;*);;

rrel_oil_content <- sc_node_role_relation;
    => nrel_main_idtf: [содержание масла в эмульсии (в процентах)](*<- lang_ru;;*);;

rrel_emulsion_stability <- sc_node_role_relation;
    => nrel_main_idtf: [стабильность эмульсии (время сохранения стабильности)](*<- lang_ru;;*);;

concept_lubrication_cooling <- sc_node_class;
    => nrel_main_idtf: [действуют как смазочные и охлаждающие жидкости, снижая трение и теплообразование](*<- lang_ru;;*);;

concept_oil_removal <- sc_node_class;
    => nrel_main_idtf: [помогают разлагать нефтяные загрязнители и удалять их из водоемов](*<- lang_ru;;*);;

concept_oils <- sc_node_class;
    => nrel_main_idtf: [масла (нефть, растительные масла)](*<- lang_ru;;*);;

concept_emulsifiers <- sc_node_class;

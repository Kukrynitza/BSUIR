subject_domain_of_substances <- sc_node_struct;;
subject_domain_of_substances => nrel_main_idtf: [Предметная область веществ] (*<- lang_ru;;*);;
subject_domain_of_substances => nrel_main_idtf: [Subject domain of substances] (*<- lang_en;;*);;

subject_domain_of_substances
                                <= nrel_section_decomposition: ...
                                                            (* <-sc_node_tuple;;
                                                              -> subject_domain_of_major_pollutants;;
                                                              -> subject_domain_of_substances_for_biogenic_nutrition;;
                                                              -> subject_domain_of_substances_to_be_removed;;
                                                              -> subject_domain_of_cleaning_reagents;;
                                                              -> subject_domain_of_sorbents_and_filter_materials;;
                                                             *);;

subject_domain_of_major_pollutants <- sc_node_struct;;
subject_domain_of_major_pollutants => nrel_main_idtf: [Предметная область основных загрязняющих веществ] (*<- lang_ru;;*);;
concept_major_pollutants <- sc_node_class;
              => nrel_main_idtf: [основные загрязняющие вещества](*<- lang_ru;;*);;

subject_domain_of_major_pollutants
                                <= nrel_partition:
                                                  concept_suspended_solids;
                                                  concept_biochemical_oxygen_demand;
                                                  concept_chemical_oxygen_demand;
                                                  concept_ammonium_ion;
                                                  concept_kjeldahl_nitrogen;
                                                  concept_total_phosphorus;
                                                  concept_phosphate_ion;
                                                  concept_chloride_ion;
                                                  concept_petroleum_products;
                                                  concept_oils_and_fats;;

subject_domain_of_substances_for_biogenic_nutrition <- sc_node_struct;;
subject_domain_of_substances_for_biogenic_nutrition => nrel_main_idtf: [Предметная область веществ для биогенной подпитки] (*<- lang_ru;;*);;
concept_substances_for_biogenic_nutrition <- sc_node_class;
              => nrel_main_idtf: [вещества для биогенной подпитки](*<- lang_ru;;*);;

subject_domain_of_substances_for_biogenic_nutrition
                                <= nrel_partition:
                                                  concept_superphosphate;
                                                  concept_orthophosphoric_acid;
                                                  concept_ammonium_sulfate;
                                                  concept_ammonium_nitrate;
                                                  concept_aqueous_ammonia;
                                                  concept_urea;
                                                  concept_diammonium_phosphate;
                                                  concept_ammophos;;

subject_domain_of_substances_to_be_removed <- sc_node_struct;;
subject_domain_of_substances_to_be_removed => nrel_main_idtf: [Предметная область веществ, подлежащих удалению] (*<- lang_ru;;*);;
concept_substances_to_be_removed <- sc_node_class;
              => nrel_main_idtf: [вещества, подлежащие удалению](*<- lang_ru;;*);;

subject_domain_of_substances_to_be_removed
                                <= nrel_partition:
                                                  concept_heavy_metals;
                                                  concept_hexavalent_chromium_compounds;
                                                  concept_oil_emulsions;
                                                  concept_oil_and_grease_contaminants;
                                                  concept_organic_compounds_lignin_surfactants;;

subject_domain_of_cleaning_reagents <- sc_node_struct;;
subject_domain_of_cleaning_reagents => nrel_main_idtf: [Предметная область реагентов для очистки] (*<- lang_ru;;*);;
concept_cleaning_reagents <- sc_node_class;
              => nrel_main_idtf: [реагенты для очистки](*<- lang_ru;;*);;

subject_domain_of_cleaning_reagents
                                <= nrel_partition:
                                                  concept_aluminum_salts_coagulants;
                                                  concept_iron_salts_coagulants;
                                                  concept_lime_CaO;
                                                  concept_anionic_flocculants;
                                                  concept_cationic_flocculants;;


subject_domain_of_sorbents_and_filter_materials <- sc_node_struct;;
subject_domain_of_sorbents_and_filter_materials => nrel_main_idtf: [Предметная область сорбентов и фильтрующих материалов] (*<- lang_ru;;*);;
concept_sorbents_and_filter_materials <- sc_node_class;
              => nrel_main_idtf: [сорбенты и фильтрующие материалы](*<- lang_ru;;*);;

subject_domain_of_sorbents_and_filter_materials
                                <= nrel_partition:
                                                  concept_activated_carbon;
                                                  concept_zeolites;;



concept_suspended_solids <- sc_node_class;
              => nrel_main_idtf: [взвешенные вещества](*<- lang_ru;;*);
              => sc_link_content: [сложные соединения органических и неорганических субстанций, находящиеся в воде во взвешенном состоянии.];;
concept_suspended_solids -> rrel_maximum_studied_object_class: concept_major_pollutants;;
concept_suspended_solids <= nrel_partition:
                                          concept_organic_suspended_solids;
                                          concept_inorganic_suspended_solids;;

nrel_partition <- sc_node_norole_relation; 
                     => nrel_main_idtf:[разбиение*] (*<- lang_ru;;*);[partition*](*<- lang_en;;*);;

nrel_application <- sc_node_norole_relation; 
                     => nrel_main_idtf:[применение*] (*<- lang_ru;;*);[application*](*<- lang_en;;*);; 

nrel_operation_principle <- sc_node_norole_relation; 
                     => nrel_main_idtf:[принцип работы*] (*<- lang_ru;;*);[operation_principle*](*<- lang_en;;*);;

nrel_technical_parameter <- sc_node_norole_relation; 
                     => nrel_main_idtf:[технические параметры*] (*<- lang_ru;;*);[technical_parameter*](*<- lang_en;;*);;

nrel_component <- sc_node_norole_relation; 
    => nrel_main_idtf:[состав*](*<- lang_ru;;*);[component*](*<- lang_en;;*);;

nrel_type <- sc_node_norole_relation; 
    => nrel_main_idtf:[тип*](*<- lang_ru;;*);[type*](*<- lang_en;;*);;

concept_inorganic_suspended_solids <- sc_node_class;
                                 => nrel_main_idtf: [неорганические: песок, глина, ржавчина](*<- lang_ru;;*);;
                                 
concept_organic_suspended_solids <- sc_node_class;
                                 => nrel_main_idtf: [органические: остатки растений, бактерии](*<- lang_ru;;*);;                                 

concept_suspended_solids -> nrel_application:
                                            concept_wastewater_treatment;
                                            concept_water_quality_monitoring;;

concept_suspended_solids -> nrel_technical_parameter:
    rrel_concentration;
    rrel_particle_size;;

    rrel_concentration <- sc_node_role_relation; 
    => nrel_main_idtf: [мг/л](*<- lang_ru;;*);;

    rrel_particle_size <- sc_node_role_relation; 
    => nrel_main_idtf: [мкм](*<- lang_ru;;*);;

concept_suspended_solids -> nrel_operation_principle:
                                            concept_sedimentation;
                                            concept_filtration;
                                            concept_coagulation;;

    concept_wastewater_treatment <- sc_node_class; 
    => nrel_main_idtf: [очистка сточных вод](*<- lang_ru;;*);;
    concept_water_quality_monitoring <- sc_node_class; 
    => nrel_main_idtf: [мониторинг качества воды](*<- lang_ru;;*);;

    concept_sedimentation <- sc_node_class;
    => nrel_main_idtf: [осаждение](*<- lang_ru;;*);;
    concept_filtration <- sc_node_class;
    => nrel_main_idtf: [фильтрация](*<- lang_ru;;*);;
    concept_coagulation <- sc_node_class;
    => nrel_main_idtf: [коагуляция](*<- lang_ru;;*);;





concept_biochemical_oxygen_demand <- sc_node_class;
    => nrel_main_idtf: [биохимическое потребление кислорода (БПК₅)](*<- lang_ru;;*);
    => sc_link_content: [количество кислорода, необходимое для биохимического окисления органических веществ микроорганизмами в воде в течение 5 суток при температуре 20°с.];;

concept_biochemical_oxygen_demand <= nrel_partition:
    concept_BOD_total;
    concept_BOD_5;
    concept_BOD_1;;

concept_biochemical_oxygen_demand -> nrel_application:
    concept_wastewater_quality_control;
    concept_treatment_efficiency_evaluation;
    concept_pollution_assessment;
    concept_aeration_calculation;;

concept_biochemical_oxygen_demand -> nrel_technical_parameter:
    rrel_unit;
    rrel_standard_duration;
    rrel_dependency_factors;;

concept_biochemical_oxygen_demand -> nrel_operation_principle:
    concept_oxidation_by_microorganisms;
    concept_oxygen_consumption;
    concept_dissolved_oxygen_drop;;

concept_biochemical_oxygen_demand -> nrel_component:
    concept_organic_pollutants;
    concept_aerobic_microorganisms;
    concept_dissolved_oxygen;;

concept_biochemical_oxygen_demand -> nrel_type:
    concept_BOD_total_type;
    concept_BOD_5_type;
    concept_BOD_1_type;;

concept_BOD_total <- sc_node_class;
    => nrel_main_idtf: [БПК полного окисления (БПК∞)](*<- lang_ru;;*);;

concept_BOD_5 <- sc_node_class;
    => nrel_main_idtf: [БПК₅ — стандартное измерение за 5 суток](*<- lang_ru;;*);;

concept_BOD_1 <- sc_node_class;
    => nrel_main_idtf: [БПК₁ — краткосрочное измерение](*<- lang_ru;;*);;


concept_wastewater_quality_control <- sc_node_class;
    => nrel_main_idtf: [контроль качества сточных и природных вод](*<- lang_ru;;*);;

concept_treatment_efficiency_evaluation <- sc_node_class;
    => nrel_main_idtf: [определение эффективности очистных сооружений](*<- lang_ru;;*);;

concept_pollution_assessment <- sc_node_class;
    => nrel_main_idtf: [оценка уровня загрязнения водоемов органическими веществами](*<- lang_ru;;*);;

concept_aeration_calculation <- sc_node_class;
    => nrel_main_idtf: [расчет необходимой аэрации в очистных сооружениях](*<- lang_ru;;*);;


rrel_unit <- sc_node_role_relation;
    => nrel_main_idtf: [мг O₂/л](*<- lang_ru;;*);;

rrel_standard_duration <- sc_node_role_relation;
    => nrel_main_idtf: [5 суток при 20°С](*<- lang_ru;;*);;

rrel_dependency_factors <- sc_node_role_relation;
    => nrel_main_idtf: [температура, концентрация микроорганизмов, состав загрязнителей](*<- lang_ru;;*);;


concept_oxidation_by_microorganisms <- sc_node_class;
    => nrel_main_idtf: [аэробные микроорганизмы окисляют органические соединения](*<- lang_ru;;*);;

concept_oxygen_consumption <- sc_node_class;
    => nrel_main_idtf: [кислород расходуется на биохимическое разложение](*<- lang_ru;;*);;

concept_dissolved_oxygen_drop <- sc_node_class;
    => nrel_main_idtf: [снижение концентрации растворённого O₂ указывает уровень загрязнения](*<- lang_ru;;*);;


concept_organic_pollutants <- sc_node_class;
    => nrel_main_idtf: [органические загрязнители (углеводы, белки, жиры)](*<- lang_ru;;*);;

concept_aerobic_microorganisms <- sc_node_class;
    => nrel_main_idtf: [аэробные бактерии и микроорганизмы](*<- lang_ru;;*);;

concept_dissolved_oxygen <- sc_node_class;
    => nrel_main_idtf: [растворённый кислород](*<- lang_ru;;*);;


concept_BOD_total_type <- sc_node_class;
    => nrel_main_idtf: [БПК полного разложения (БПК∞)](*<- lang_ru;;*);;

concept_BOD_5_type <- sc_node_class;
    => nrel_main_idtf: [БПК₅ — стандартный лабораторный тест](*<- lang_ru;;*);;

concept_BOD_1_type <- sc_node_class;
    => nrel_main_idtf: [БПК₁ — экспресс-анализ](*<- lang_ru;;*);;





concept_chemical_oxygen_demand <- sc_node_class;
    => nrel_main_idtf: [химическое потребление кислорода (ХПК)](*<- lang_ru;;*);
    => sc_link_content: [количество кислорода, необходимое для окисления органических и неорганических веществ в воде сильными окислителями (например, дихроматом калия) при стандартных условиях.];;

concept_chemical_oxygen_demand <= nrel_partition:
    concept_COD_organic;
    concept_COD_inorganic;;

concept_chemical_oxygen_demand -> nrel_application:
    concept_wastewater_monitoring;
    concept_total_pollution_assessment;
    concept_treatment_efficiency_check;
    concept_ecological_monitoring;;

concept_chemical_oxygen_demand -> nrel_technical_parameter:
    rrel_unit;
    rrel_standard_method;
    rrel_reaction_time;;

concept_chemical_oxygen_demand -> nrel_operation_principle:
    concept_strong_oxidizers_use;
    concept_oxygen_consumption_for_oxidation;;

concept_chemical_oxygen_demand -> nrel_component:
    concept_organic_pollutants;
    concept_inorganic_pollutants;
    concept_oxidizing_agents;;

concept_chemical_oxygen_demand -> nrel_type:
    concept_COD_organic_type;
    concept_COD_inorganic_type;;


concept_COD_organic <- sc_node_class;
    => nrel_main_idtf: [ХПК органических веществ](*<- lang_ru;;*);;

concept_COD_inorganic <- sc_node_class;
    => nrel_main_idtf: [ХПК неорганических веществ](*<- lang_ru;;*);;



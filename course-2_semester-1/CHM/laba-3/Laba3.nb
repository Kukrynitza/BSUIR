      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{
         RowBox[{"\"\<X\>\"", "[", "0", "]"}], ",", "\"\<=\>\"", ",", "X"}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"error", ">", "e"}], ",", 

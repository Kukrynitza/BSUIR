concept_substances_for_biogenic_nutrition <- sc_node_class;
              => nrel_main_idtf: [вещества для биогенной подпитки](*<- lang_ru;;*);
            => sc_link_content: [вещества, обеспечивающие микроорганизмы необходимыми элементами (азот, фосфор, калий и микроэлементы) для поддержания биохимических процессов, таких как очистка сточных вод или биологическое разложение.];;
concept_substances_for_biogenic_nutrition
                                => nrel_partition:
                                                  concept_superphosphate;
                                                  concept_orthophosphoric_acid;
                                                  concept_ammonium_sulfate;
                                                  concept_ammonium_nitrate;
                                                  concept_aqueous_ammonia;
                                                  concept_urea;
                                                  concept_diammonium_phosphate;
                                                  concept_ammophos;;




concept_superphosphate <- sc_node_class;
    => nrel_main_idtf: [суперфосфат](*<- lang_ru;;*);
    => sc_link_content: [минеральное удобрение, содержащее моно- и дигидрофосфаты кальция, получаемое из фосфатных руд, используемое для питания растений и как источник фосфора.];;
concept_superphosphate -> rrel_maximum_studied_object_class: concept_substances_for_biogenic_nutrition;;
concept_superphosphate => nrel_partition:
    concept_single_superphosphate;
    concept_double_superphosphate;;

concept_superphosphate => nrel_application:
    concept_agricultural_fertilizer_use;
    concept_soil_phosphorus_restoration;
    concept_agronomy_application;;

concept_superphosphate => nrel_technical_parameter:
    rrel_phosphorus_content;
    rrel_phosphate_solubility;;

concept_superphosphate => nrel_operation_principle:
    concept_plant_phosphorus_supply;
    concept_soil_dissolution_availability;;

concept_superphosphate => nrel_component:
    concept_calcium_monophosphate;
    concept_calcium_dihydrogen_phosphate;
    concept_free_calcium_and_sulfur;;

concept_superphosphate => nrel_type:
    concept_single_superphosphate_type;
    concept_double_superphosphate_type;;


concept_single_superphosphate <- sc_node_class;
    => nrel_main_idtf: [простой суперфосфат (содержит монофосфат кальция)](*<- lang_ru;;*);;

concept_double_superphosphate <- sc_node_class;
    => nrel_main_idtf: [двойной суперфосфат (содержит дигидрофосфат кальция, повышенное содержание фосфора)](*<- lang_ru;;*);;

concept_agricultural_fertilizer_use <- sc_node_class;

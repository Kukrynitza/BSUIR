concept_petroleum_products <- sc_node_class;
    => nrel_main_idtf: [нефтепродукты](*<- lang_ru;;*);
    => sc_link_content: [органические вещества, получаемые при переработке нефти, включая углеводороды и их производные, которые могут попадать в сточные воды в виде загрязнителей.];;
concept_petroleum_products -> rrel_maximum_studied_object_class: concept_major_pollutants;;
concept_petroleum_products => nrel_partition:
    concept_hydrocarbons;
    concept_petroleum_chemicals;;

concept_petroleum_products => nrel_application:
    concept_industrial_pollution_control;
    concept_water_pollution_monitoring_near_oil_fields;
    concept_oil_removal_in_treatment_plants;;

concept_petroleum_products => nrel_technical_parameter:
    rrel_petroleum_products_concentration;
    rrel_measurement_methods;;

concept_petroleum_products => nrel_operation_principle:
    concept_coagulation_flokculation_adsorption;
    concept_biological_treatment_inefficiency;;

concept_petroleum_products => nrel_component:
    concept_hydrocarbons;
    concept_petroleum_chemicals;;

concept_petroleum_products => nrel_type:
    concept_oil_hydrocarbons_type;
    concept_petroleum_chemical_products_type;;


concept_hydrocarbons <- sc_node_class;
    => nrel_main_idtf: [углеводороды (нефть и её фракции, такие как бензин, дизельное топливо, мазут)](*<- lang_ru;;*);;

concept_petroleum_chemicals <- sc_node_class;
    => nrel_main_idtf: [нефтехимические вещества (например, синтетические смолы и растворители)](*<- lang_ru;;*);;

concept_industrial_pollution_control <- sc_node_class;
    => nrel_main_idtf: [контроль загрязнения сточных вод от промышленных объектов (нефтехимические предприятия, автозаправочные станции)](*<- lang_ru;;*);;

concept_water_pollution_monitoring_near_oil_fields <- sc_node_class;
    => nrel_main_idtf: [мониторинг загрязнения водоёмов вблизи нефтяных месторождений и трубопроводов](*<- lang_ru;;*);;

concept_oil_removal_in_treatment_plants <- sc_node_class;
    => nrel_main_idtf: [очистка воды от нефтепродуктов на очистных сооружениях](*<- lang_ru;;*);;

rrel_petroleum_products_concentration <- sc_node_role_relation;
    => nrel_main_idtf: [концентрация нефтепродуктов в сточных водах (мг/л)](*<- lang_ru;;*);;

rrel_measurement_methods <- sc_node_role_relation;
    => nrel_main_idtf: [методы измерения — флуресцентные методы, газовая хроматография](*<- lang_ru;;*);;

concept_coagulation_flokculation_adsorption <- sc_node_class;
    => nrel_main_idtf: [нефтепродукты могут быть удалены с помощью коагуляции, флокуляции и адсорбции на углеродных фильтрах](*<- lang_ru;;*);;

concept_biological_treatment_inefficiency <- sc_node_class;
    => nrel_main_idtf: [биологическая очистка может быть менее эффективной из-за устойчивости некоторых нефтепродуктов к разложению](*<- lang_ru;;*);;

concept_oil_hydrocarbons_type <- sc_node_class;

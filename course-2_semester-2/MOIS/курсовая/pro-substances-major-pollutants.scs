    => nrel_main_idtf: [фосфат в осадках](*<- lang_ru;;*);;

concept_phosphate_removal <- sc_node_class;
    => nrel_main_idtf: [очистка сточных вод (удаление фосфатов)](*<- lang_ru;;*);;

concept_eutrophication_prevention <- sc_node_class;
    => nrel_main_idtf: [мониторинг загрязнения водоёмов (предотвращение эвтрофикации)](*<- lang_ru;;*);;


    => sc_link_content: [неорганическое удобрение, содержащее азот и фосфор, используемое для улучшения роста растений и улучшения качества почвы];;
concept_diammonium_phosphate -> rrel_maximum_studied_object_class: concept_substances_for_biogenic_nutrition;;
concept_diammonium_phosphate => nrel_partition:
    concept_dap_as_fertilizer;
    concept_dap_in_industry;;

concept_diammonium_phosphate => nrel_application:
    concept_agriculture;
    concept_chemical_industry;;

concept_diammonium_phosphate => nrel_technical_parameter:
    rrel_nitrogen_content;
    rrel_phosphorus_content;
    rrel_solubility;;

concept_diammonium_phosphate => nrel_operation_principle:
    concept_dap_effect_in_soil;
    concept_phosphorus_role_in_plants;;

concept_diammonium_phosphate => nrel_component:
    concept_ammonium_ion;
    concept_phosphate_ion;;

concept_diammonium_phosphate => nrel_type:
    concept_granular_dap;
    concept_powder_dap;;


concept_dap_as_fertilizer <- sc_node_class;
    => nrel_main_idtf: [диаммонийфосфат как удобрение](*<- lang_ru;;*);;

concept_dap_in_industry <- sc_node_class;
    => nrel_main_idtf: [диаммонийфосфат в промышленности](*<- lang_ru;;*);;

concept_agriculture <- sc_node_class;
    => nrel_main_idtf: [сельское хозяйство (удобрение, источник фосфора и азота для растений)](*<- lang_ru;;*);;

concept_chemical_industry <- sc_node_class;
    => nrel_main_idtf: [химическая промышленность (производство других фосфорных соединений)](*<- lang_ru;;*);;

rrel_nitrogen_content <- sc_node_role_relation;
    => nrel_main_idtf: [содержание азота (обычно около 18-20%)](*<- lang_ru;;*);;

rrel_phosphorus_content <- sc_node_role_relation;
    => nrel_main_idtf: [содержание фосфора (обычно около 46-48% P₂O₅)](*<- lang_ru;;*);;

rrel_solubility <- sc_node_role_relation;
    => nrel_main_idtf: [растворимость в воде](*<- lang_ru;;*);;

concept_dap_effect_in_soil <- sc_node_class;
    => nrel_main_idtf: [обеспечивает растениям доступный азот и фосфор, способствуя росту и урожайности](*<- lang_ru;;*);;

concept_phosphorus_role_in_plants <- sc_node_class;
    => nrel_main_idtf: [фосфор участвует в энергетическом обмене и фотосинтезе растений](*<- lang_ru;;*);;

concept_ammonium_ion <- sc_node_class;
    => nrel_main_idtf: [аммоний-ион (NH₄⁺)](*<- lang_ru;;*);;

concept_phosphate_ion <- sc_node_class;
    => nrel_main_idtf: [фосфат-ион (HPO₄²⁻)](*<- lang_ru;;*);;

concept_granular_dap <- sc_node_class;
    => nrel_main_idtf: [гранулированный диаммонийфосфат](*<- lang_ru;;*);;

concept_powder_dap <- sc_node_class;
    => nrel_main_idtf: [порошковый диаммонийфосфат](*<- lang_ru;;*);;






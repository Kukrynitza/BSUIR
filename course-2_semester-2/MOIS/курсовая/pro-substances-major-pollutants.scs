concept_no_biological_involvement <- sc_node_class;
    => nrel_main_idtf: [хлорид-ион обычно не участвует в биологических процессах очистки воды, но может влиять на коррозию оборудования очистных сооружений](*<- lang_ru;;*);;

concept_source_in_wastewater <- sc_node_class;
    => nrel_main_idtf: [хлориды присутствуют в сточных водах в результате растворения солей и продуктов жизнедеятельности человека](*<- lang_ru;;*);;

concept_chloride_compounds <- sc_node_class;

    => nrel_main_idtf: [аммоний-ион (азот аммонийный)](*<- lang_ru;;*);
    => sc_link_content: [положительно заряженный ион аммония, образующийся при диссоциации аммиака в воде, часто встречается в сточных водах.];;

concept_ammonium_ion <= nrel_partition:
    concept_ammonium_in_wastewater;
    concept_ammonium_in_sludge;;

concept_ammonium_ion -> nrel_application:
    concept_ammonium_removal;
    concept_ammonia_neutralization;
    concept_pollution_monitoring;;

concept_ammonium_ion -> nrel_technical_parameter:

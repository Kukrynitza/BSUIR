concept_toxicity <- sc_node_class;
    => nrel_main_idtf: [жиро- и нефтесодержащие примеси могут оказывать токсическое воздействие на водные экосистемы](*<- lang_ru;;*);;

concept_removal_processes <- sc_node_class;
    => nrel_main_idtf: [загрязнители удаляются с помощью процессов флотации, абсорбции и фильтрации](*<- lang_ru;;*);;

concept_hydrocarbons <- sc_node_class;
    => nrel_main_idtf: [углеводороды (нефть и нефтепродукты)](*<- lang_ru;;*);;

concept_fatty_acids_derivatives <- sc_node_class;
    => nrel_main_idtf: [жирные кислоты и их производные (масла и жиры)](*<- lang_ru;;*);;

concept_petroleum_contaminants <- sc_node_class;
    => nrel_main_idtf: [нефтесодержащие примеси](*<- lang_ru;;*);;

concept_fatty_and_emulsion_contaminants <- sc_node_class;
    => nrel_main_idtf: [жиро- и эмульсионные загрязнители](*<- lang_ru;;*);;





concept_organic_compounds_lignin_surfactants <- sc_node_class;
    => nrel_main_idtf: [органические соединения (лигнин, ПАВ)](*<- lang_ru;;*);
    => sc_link_content: [органические вещества, такие как лигнин и поверхностно-активные вещества (ПАВ), которые могут быть источниками загрязнения в сточных водах, воздействуют на водные экосистемы и могут нарушать работу очистных сооружений];;
concept_organic_compounds_lignin_surfactants -> rrel_maximum_studied_object_class: concept_substances_to_be_removed;;
concept_organic_compounds_lignin_surfactants => nrel_partition:
    concept_lignin;
    concept_surfactants;;

concept_organic_compounds_lignin_surfactants => nrel_application:
    concept_paper_industry;
    concept_chemical_industry;
    concept_wastewater_treatment;;

concept_organic_compounds_lignin_surfactants => nrel_technical_parameter:
    rrel_lignin_surfactant_concentration;
    rrel_toxicity_to_aquatic_organisms;;

concept_organic_compounds_lignin_surfactants => nrel_operation_principle:
    concept_lignin_degradation;
    concept_surfactant_impact;;

concept_organic_compounds_lignin_surfactants => nrel_component:
    concept_lignin_component;
    concept_surfactants_component;;

concept_organic_compounds_lignin_surfactants => nrel_type:
    concept_lignin_type;
    concept_surfactant_type;;


concept_lignin <- sc_node_class;
    => nrel_main_idtf: [лигнин](*<- lang_ru;;*);;

concept_surfactants <- sc_node_class;
    => nrel_main_idtf: [ПАВ (поверхностно-активные вещества)](*<- lang_ru;;*);;

concept_paper_industry <- sc_node_class;
    => nrel_main_idtf: [производство бумаги и картона (лигнин используется в качестве побочного продукта в процессе производства)](*<- lang_ru;;*);;

concept_chemical_industry <- sc_node_class;
    => nrel_main_idtf: [химическая промышленность (ПАВ применяются в моющих средствах, косметике, производстве текстиля)](*<- lang_ru;;*);;

concept_wastewater_treatment <- sc_node_class;
    => nrel_main_idtf: [очистка сточных вод (удаление ПАВ и органических загрязнителей из воды)](*<- lang_ru;;*);;

rrel_lignin_surfactant_concentration <- sc_node_role_relation;
    => nrel_main_idtf: [концентрация лигнина и ПАВ в сточных водах (мг/л или г/м³)](*<- lang_ru;;*);;

rrel_toxicity_to_aquatic_organisms <- sc_node_role_relation;
    => nrel_main_idtf: [токсичность для водных организмов (особенно для ПАВ)](*<- lang_ru;;*);;

concept_lignin_degradation <- sc_node_class;
    => nrel_main_idtf: [лигнин, как органическое соединение, может разрушаться в природных условиях, но в сточных водах он часто приводит к образованию осадков и помутнению воды](*<- lang_ru;;*);;

concept_surfactant_impact <- sc_node_class;
    => nrel_main_idtf: [ПАВ могут нарушать баланс водных экосистем, снижая растворимость кислорода в воде и влияя на жизнь водных организмов, таких как рыбы и водоросли](*<- lang_ru;;*);;

concept_lignin_component <- sc_node_class;
    => nrel_main_idtf: [лигнин (органическое полимерное соединение)](*<- lang_ru;;*);;

concept_surfactants_component <- sc_node_class;
    => nrel_main_idtf: [ПАВ (например, анионные, катионные, неионогенные и амфотерные соединения)](*<- lang_ru;;*);;

concept_lignin_type <- sc_node_class;
    => nrel_main_idtf: [лигнин (в основном из древесины)](*<- lang_ru;;*);;

concept_surfactant_type <- sc_node_class;
    => nrel_main_idtf: [ПАВ (моющие средства, эмульгаторы, средства для обработки текстиля)](*<- lang_ru;;*);;

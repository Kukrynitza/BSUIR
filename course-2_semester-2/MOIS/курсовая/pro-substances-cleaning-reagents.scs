    => nrel_main_idtf: [сульфат алюминия (Al₂(SO₄)₃)](*<- lang_ru;;*);;

concept_aluminum_chloride <- sc_node_class;
    => nrel_main_idtf: [хлорид алюминия (AlCl₃)](*<- lang_ru;;*);;


    concept_oil_removal;;

concept_oil_emulsions => nrel_component:
    concept_oils;
    concept_emulsifiers;;

concept_oil_emulsions => nrel_type:
    concept_mineral_oil_emulsions;
    concept_vegetable_oil_emulsions;;



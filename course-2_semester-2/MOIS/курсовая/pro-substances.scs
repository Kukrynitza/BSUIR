concept_coconut_shell_type <- sc_node_class;
    => nrel_main_idtf: [уголь на основе кокосовой скорлупы](*<- lang_ru;;*);;

concept_wood_type <- sc_node_class;
    => nrel_main_idtf: [уголь на основе древесины](*<- lang_ru;;*);;




concept_zeolites <- sc_node_class;
    => nrel_main_idtf: [цеолиты](*<- lang_ru;;*);
    => sc_link_content: [минеральные соединения, обладающие пористой структурой, используемые для очистки воды, адсорбции и обмена ионами. Цеолиты широко применяются в очистных сооружениях для удаления аммония, тяжелых металлов и других загрязнителей];;

concept_zeolites <= nrel_partition:
    concept_sodium_zeolites;
    concept_potassium_zeolites;
    concept_synthetic_zeolites;;

concept_zeolites -> nrel_application:
    concept_wastewater_treatment;
    concept_water_purification;
    concept_agriculture;
    concept_air_and_gas_purification;;

concept_zeolites -> nrel_technical_parameter:
    rrel_ion_exchange_capacity;
    rrel_porous_structure;
    rrel_adsorption_efficiency;;

concept_zeolites -> nrel_operation_principle:
    concept_ion_exchange;
    concept_adsorption_process;;

concept_zeolites -> nrel_component:
    concept_natural_zeolites;
    concept_synthetic_zeolites;;

concept_zeolites -> nrel_type:
    concept_sodium_type;
    concept_potassium_type;
    concept_synthetic_type;;


concept_sodium_zeolites <- sc_node_class;
    => nrel_main_idtf: [натриевые цеолиты](*<- lang_ru;;*);;

concept_potassium_zeolites <- sc_node_class;
    => nrel_main_idtf: [калиевые цеолиты](*<- lang_ru;;*);;

concept_synthetic_zeolites <- sc_node_class;
    => nrel_main_idtf: [синтетические цеолиты](*<- lang_ru;;*);;

concept_wastewater_treatment <- sc_node_class;
    => nrel_main_idtf: [очистка сточных вод (удаление аммония, тяжелых металлов и других загрязнителей)](*<- lang_ru;;*);;

concept_water_purification <- sc_node_class;
    => nrel_main_idtf: [водоочистка на водоочистных станциях](*<- lang_ru;;*);;

concept_agriculture <- sc_node_class;
    => nrel_main_idtf: [сельское хозяйство (для улучшения качества почвы и водообмена)](*<- lang_ru;;*);;

concept_air_and_gas_purification <- sc_node_class;
    => nrel_main_idtf: [очистка газов и воздуха](*<- lang_ru;;*);;

rrel_ion_exchange_capacity <- sc_node_role_relation;
    => nrel_main_idtf: [ионная обменная способность цеолита (мг-экв/г)](*<- lang_ru;;*);;

rrel_porous_structure <- sc_node_role_relation;
    => nrel_main_idtf: [пористость цеолита и его удельная поверхность](*<- lang_ru;;*);;

rrel_adsorption_efficiency <- sc_node_role_relation;
    => nrel_main_idtf: [эффективность адсорбции для различных загрязнителей](*<- lang_ru;;*);;

concept_ion_exchange <- sc_node_class;
    => nrel_main_idtf: [цеолиты работают путем обмена ионами — ионы загрязнителей, такие как аммоний, могут заменяться на безопасные ионы (например, натрий или калий)](*<- lang_ru;;*);;

concept_adsorption_process <- sc_node_class;
    => nrel_main_idtf: [они также обладают способностью адсорбировать органические и неорганические вещества благодаря своей пористой структуре, что помогает очищать воду и воздух](*<- lang_ru;;*);;

concept_natural_zeolites <- sc_node_class;
    => nrel_main_idtf: [природные цеолиты (например, клиноптилолит)](*<- lang_ru;;*);;

concept_synthetic_zeolites <- sc_node_class;
    => nrel_main_idtf: [синтетические цеолиты (например, фаунапоатит, офтальмоклацит)](*<- lang_ru;;*);;

concept_sodium_type <- sc_node_class;
    => nrel_main_idtf: [натриевые цеолиты](*<- lang_ru;;*);;

concept_potassium_type <- sc_node_class;
    => nrel_main_idtf: [калиевые цеолиты](*<- lang_ru;;*);;

concept_synthetic_type <- sc_node_class;
    => nrel_main_idtf: [синтетические цеолиты (например, для специализированных очистных процессов)](*<- lang_ru;;*);;


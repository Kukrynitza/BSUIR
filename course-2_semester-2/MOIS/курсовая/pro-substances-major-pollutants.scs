concept_oils_and_fats <- sc_node_class;
    => nrel_main_idtf: [масла и жиры](*<- lang_ru;;*);
    => sc_link_content: [органические вещества, состоящие из триглицеридов жирных кислот, которые могут загрязнять сточные воды и осадки, поступая с промышленными и бытовыми отходами.];;
concept_oils_and_fats -> rrel_maximum_studied_object_class: concept_major_pollutants;;
concept_oils_and_fats => nrel_partition:
    concept_vegetable_oils;
    concept_animal_fats;
    concept_synthetic_oils;;

concept_oils_and_fats => nrel_application:
    concept_food_industry_pollution_control;
    concept_wastewater_treatment;
    concept_waste_management_in_industries;;

concept_oils_and_fats => nrel_technical_parameter:
    rrel_oils_and_fats_concentration;
    rrel_volatile_and_nonvolatile_content;;

concept_oils_and_fats => nrel_operation_principle:
    concept_physical_chemical_methods;
    concept_adsorption_materials;;

concept_oils_and_fats => nrel_component:
    concept_vegetable_oils_component;
    concept_animal_fats_component;
    concept_synthetic_oils_fats_component;;

concept_oils_and_fats => nrel_type:
    concept_vegetable_oil_type;
    concept_animal_fat_type;
    concept_synthetic_oils_fats_type;;



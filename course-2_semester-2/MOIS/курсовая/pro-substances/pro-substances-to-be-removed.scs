    concept_fatty_acids_derivatives;;

concept_oil_and_grease_contaminants => nrel_type:
    concept_petroleum_contaminants;
    concept_fatty_and_emulsion_contaminants;;


concept_animal_oils_fats <- sc_node_class;
    => nrel_main_idtf: [масла и жиры животного происхождения](*<- lang_ru;;*);;

concept_vegetable_oils_fats <- sc_node_class;
    => nrel_main_idtf: [масла и жиры растительного происхождения](*<- lang_ru;;*);;

concept_petroleum_products <- sc_node_class;
    => nrel_main_idtf: [нефтепродукты](*<- lang_ru;;*);;

concept_wastewater_treatment <- sc_node_class;
    => nrel_main_idtf: [очистка сточных вод (удаление загрязнителей из водоемов и трубопроводных систем)](*<- lang_ru;;*);;

concept_petroleum_chemical_industry <- sc_node_class;
    => nrel_main_idtf: [нефтехимическая промышленность (переработка и очистка нефтепродуктов)](*<- lang_ru;;*);;

concept_automotive_industry <- sc_node_class;
    => nrel_main_idtf: [автомобильная промышленность и сервис (уход за автотранспортом и утечками из техники)](*<- lang_ru;;*);;

rrel_oil_and_fat_content <- sc_node_role_relation;

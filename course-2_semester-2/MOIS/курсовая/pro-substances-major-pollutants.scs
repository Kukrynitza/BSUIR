    => nrel_main_idtf: [мг O₂/л](*<- lang_ru;;*);;

rrel_standard_duration <- sc_node_role_relation;
    => nrel_main_idtf: [5 суток при 20°С](*<- lang_ru;;*);;

rrel_dependency_factors <- sc_node_role_relation;
    => nrel_main_idtf: [температура, концентрация микроорганизмов, состав загрязнителей](*<- lang_ru;;*);;


concept_oxidation_by_microorganisms <- sc_node_class;
    => nrel_main_idtf: [аэробные микроорганизмы окисляют органические соединения](*<- lang_ru;;*);;

concept_oxygen_consumption <- sc_node_class;
    => nrel_main_idtf: [кислород расходуется на биохимическое разложение](*<- lang_ru;;*);;


    => nrel_main_idtf: [поликарбоксилат алюминия](*<- lang_ru;;*);;

concept_drinking_wastewater_treatment <- sc_node_class;
    => nrel_main_idtf: [очистка питьевой воды и сточных вод (коагуляция для удаления взвешенных частиц)](*<- lang_ru;;*);;

concept_water_treatment_plants <- sc_node_class;
    => nrel_main_idtf: [очистка воды на водоочистных станциях](*<- lang_ru;;*);;

concept_industrial_water_preparation <- sc_node_class;
    => nrel_main_idtf: [использование в промышленной водоподготовке и очистке воды в разных отраслях (например, в текстильной промышленности)](*<- lang_ru;;*);;

rrel_coagulant_concentration <- sc_node_role_relation;
    => nrel_main_idtf: [концентрация коагулянта в растворе (мг/л)](*<- lang_ru;;*);;

rrel_ph_efficiency <- sc_node_role_relation;
    => nrel_main_idtf: [pH воды, при котором коагулянт проявляет максимальную эффективность](*<- lang_ru;;*);;

concept_coagulation_process <- sc_node_class;
    => nrel_main_idtf: [коагулянты, такие как соли алюминия, помогают агрегировать мелкие частицы и взвешенные вещества в воду, образуя флокулы, которые легче удаляются в процессе фильтрации](*<- lang_ru;;*);;

concept_neutralization <- sc_node_class;
    => nrel_main_idtf: [при добавлении в воду соли алюминия взаимодействуют с частицами загрязнителей, нейтрализуя их заряд и способствуя образованию осадков](*<- lang_ru;;*);;


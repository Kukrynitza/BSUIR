concept_substances_to_be_removed <- sc_node_class;
              => nrel_main_idtf: [вещества, подлежащие удалению](*<- lang_ru;;*);
            => sc_link_content: [группа веществ, подлежащих удалению в процессе водоочистки из-за их вредного воздействия на здоровье человека, окружающую среду или нарушение технологических процессов.
];;

concept_substances_to_be_removed
                                => nrel_partition:
                                                  concept_heavy_metals;
                                                  concept_hexavalent_chromium_compounds;
                                                  concept_oil_emulsions;
                                                  concept_oil_and_grease_contaminants;
                                                  concept_organic_compounds_lignin_surfactants;;





concept_heavy_metals <- sc_node_class;
    => nrel_main_idtf: [тяжелые металлы](*<- lang_ru;;*);
    => sc_link_content: [металлические элементы с высокой плотностью, которые могут быть токсичными для живых организмов даже при низких концентрациях, часто обнаруживаются в сточных водах и загрязняют окружающую среду];;
concept_heavy_metals -> rrel_maximum_studied_object_class: concept_substances_to_be_removed;;
concept_heavy_metals => nrel_partition:
    concept_cadmium;
    concept_lead;
    concept_mercury;
    concept_chromium;
    concept_arsenic;;

concept_heavy_metals => nrel_application:
    concept_wastewater_treatment;
    concept_ecological_monitoring;
    concept_health_risk_management;;

concept_heavy_metals => nrel_technical_parameter:
    rrel_concentration;
    rrel_toxicity;;

concept_heavy_metals => nrel_operation_principle:
    concept_toxic_effect;
    concept_bioaccumulation;;

concept_heavy_metals => nrel_component:
    concept_cadmium;
    concept_lead;
    concept_mercury;
    concept_chromium;
    concept_arsenic;;

concept_heavy_metals => nrel_type:
    concept_heavy_metals_in_wastewater;
    concept_heavy_metals_in_soil;;


concept_cadmium <- sc_node_class;
    => nrel_main_idtf: [кадиум (Cd)](*<- lang_ru;;*);;

concept_lead <- sc_node_class;
    => nrel_main_idtf: [свинец (Pb)](*<- lang_ru;;*);;

concept_mercury <- sc_node_class;
    => nrel_main_idtf: [ртуть (Hg)](*<- lang_ru;;*);;

concept_chromium <- sc_node_class;
    => nrel_main_idtf: [хром (Cr)](*<- lang_ru;;*);;

concept_arsenic <- sc_node_class;
    => nrel_main_idtf: [мышьяк (As)](*<- lang_ru;;*);;

concept_wastewater_treatment <- sc_node_class;
    => nrel_main_idtf: [контроль загрязнения сточных вод на очистных сооружениях](*<- lang_ru;;*);;

concept_ecological_monitoring <- sc_node_class;
    => nrel_main_idtf: [мониторинг экологической безопасности в промышленных районах](*<- lang_ru;;*);;

concept_health_risk_management <- sc_node_class;
    => nrel_main_idtf: [санитарные исследования и управление рисками для здоровья населения](*<- lang_ru;;*);;

rrel_concentration <- sc_node_role_relation;
    => nrel_main_idtf: [концентрация тяжелых металлов в сточных водах и осадках (мкг/л или мг/л)](*<- lang_ru;;*);;

rrel_toxicity <- sc_node_role_relation;
    => nrel_main_idtf: [токсичность элементов для флоры и фауны (например, предельно допустимые концентрации)](*<- lang_ru;;*);;

concept_toxic_effect <- sc_node_class;
    => nrel_main_idtf: [тяжелые металлы оказывают токсическое воздействие на живые организмы, нарушая физиологические процессы](*<- lang_ru;;*);;

concept_bioaccumulation <- sc_node_class;
    => nrel_main_idtf: [могут накапливаться в биологических системах, вызывая долгосрочные экологические и здоровьесберегающие риски](*<- lang_ru;;*);;

concept_heavy_metals_in_wastewater <- sc_node_class;
    => nrel_main_idtf: [тяжелые металлы, встречающиеся в сточных водах](*<- lang_ru;;*);;

concept_heavy_metals_in_soil <- sc_node_class;
    => nrel_main_idtf: [тяжелые металлы, загрязняющие почву и водоемы](*<- lang_ru;;*);;





concept_hexavalent_chromium_compounds <- sc_node_class;
    => nrel_main_idtf: [соединения шестивалентного хрома](*<- lang_ru;;*);
    => sc_link_content: [химические соединения, содержащие хром в степени окисления +6, обладающие высокой токсичностью и канцерогенным воздействием, часто встречаются в сточных водах и промышленных отходах];;
concept_hexavalent_chromium_compounds -> rrel_maximum_studied_object_class: concept_substances_to_be_removed;;
concept_hexavalent_chromium_compounds => nrel_partition:
    concept_chromium_trioxide;
    concept_chromates;
    concept_dichromates;;

concept_hexavalent_chromium_compounds => nrel_application:
    concept_chroming;
    concept_dye_industry;
    concept_metal_processing;;

concept_hexavalent_chromium_compounds => nrel_technical_parameter:
    rrel_concentration;
    rrel_toxicity;;

concept_hexavalent_chromium_compounds => nrel_operation_principle:
    concept_oxidative_damage;
    concept_high_solubility;;

concept_hexavalent_chromium_compounds => nrel_component:
    concept_chromium_6_plus;
    concept_chromic_acid;;

concept_hexavalent_chromium_compounds => nrel_type:
    concept_chromates;
    concept_dichromates;;


concept_chromium_trioxide <- sc_node_class;
    => nrel_main_idtf: [хромовый ангидрид (CrO₃)](*<- lang_ru;;*);;

concept_chromates <- sc_node_class;
    => nrel_main_idtf: [хроматы (например, натриевый хромат, Na₂CrO₄)](*<- lang_ru;;*);;

concept_dichromates <- sc_node_class;
    => nrel_main_idtf: [дихроматы (например, калийный дихромат, K₂Cr₂O₇)](*<- lang_ru;;*);;

concept_chroming <- sc_node_class;
    => nrel_main_idtf: [хромирование и антикоррозийная обработка](*<- lang_ru;;*);;

concept_dye_industry <- sc_node_class;
    => nrel_main_idtf: [производство красителей и пигментов](*<- lang_ru;;*);;

concept_metal_processing <- sc_node_class;
    => nrel_main_idtf: [обработка металлов и производство легированных сталей](*<- lang_ru;;*);;

rrel_concentration <- sc_node_role_relation;
    => nrel_main_idtf: [концентрация шестивалентного хрома в сточных водах (мкг/л или мг/л)](*<- lang_ru;;*);;

rrel_toxicity <- sc_node_role_relation;
    => nrel_main_idtf: [токсичность для экосистем и человека (предельно допустимые концентрации, PEL)](*<- lang_ru;;*);;

concept_oxidative_damage <- sc_node_class;
    => nrel_main_idtf: [соединения являются сильными окислителями, вызывающими повреждения биологических молекул, мутации и рак](*<- lang_ru;;*);;

concept_high_solubility <- sc_node_class;
    => nrel_main_idtf: [высокая растворимость в воде облегчает их проникновение в экосистемы и организм человека](*<- lang_ru;;*);;

concept_chromium_6_plus <- sc_node_class;
    => nrel_main_idtf: [хром (Cr⁶⁺)](*<- lang_ru;;*);;

concept_chromic_acid <- sc_node_class;
    => nrel_main_idtf: [хромовая кислота (H₂CrO₄)](*<- lang_ru;;*);;





concept_oil_emulsions <- sc_node_class;
    => nrel_main_idtf: [маслоэмульсионные соединения](*<- lang_ru;;*);
    => sc_link_content: [соединения, представляющие собой смеси масла и воды, стабилизированные эмульгаторами, часто используемые в качестве смазочных материалов, а также встречаются в сточных водах с нефтяными загрязнениями];;
concept_oil_emulsions -> rrel_maximum_studied_object_class: concept_substances_to_be_removed;;
concept_oil_emulsions => nrel_partition:
    concept_petroleum_based_emulsions;
    concept_vegetable_animal_oil_emulsions;;

concept_oil_emulsions => nrel_application:
    concept_industry;
    concept_agriculture;
    concept_wastewater_treatment;;

concept_oil_emulsions => nrel_technical_parameter:

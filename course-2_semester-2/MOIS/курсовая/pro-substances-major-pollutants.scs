concept_chemical_oxygen_demand <- sc_node_class;
    => nrel_main_idtf: [химическое потребление кислорода (ХПК)](*<- lang_ru;;*);
    => sc_link_content: [количество кислорода, необходимое для окисления органических и неорганических веществ в воде сильными окислителями (например, дихроматом калия) при стандартных условиях.];;
concept_chemical_oxygen_demand -> rrel_maximum_studied_object_class: concept_major_pollutants;;
concept_chemical_oxygen_demand => nrel_partition:
    concept_COD_organic;
    concept_COD_inorganic;;

concept_chemical_oxygen_demand => nrel_application:
    concept_wastewater_monitoring;
    concept_total_pollution_assessment;
    concept_treatment_efficiency_check;
    concept_ecological_monitoring;;


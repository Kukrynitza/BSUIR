subject_domain_of_major_pollutants <- sc_node_struct;;
subject_domain_of_major_pollutants => nrel_main_idtf: [Предметная область основных загрязняющих веществ] (*<- lang_ru;;*);;
concept_major_pollutants <- sc_node_class;
              => nrel_main_idtf: [основные загрязняющие вещества](*<- lang_ru;;*);;

subject_domain_of_major_pollutants
                                => nrel_partition:
                                                  concept_suspended_solids;
                                                  concept_biochemical_oxygen_demand;
                                                  concept_chemical_oxygen_demand;
                                                  concept_ammonium_ion;
                                                  concept_kjeldahl_nitrogen;
                                                  concept_total_phosphorus;
                                                  concept_phosphate_ion;
                                                  concept_chloride_ion;
                                                  concept_petroleum_products;
                                                  concept_oils_and_fats;;




concept_suspended_solids <- sc_node_class;
              => nrel_main_idtf: [взвешенные вещества](*<- lang_ru;;*);
              => sc_link_content: [сложные соединения органических и неорганических субстанций, находящиеся в воде во взвешенном состоянии.];;
concept_suspended_solids -> rrel_maximum_studied_object_class: concept_major_pollutants;;
concept_suspended_solids => nrel_partition:
                                          concept_organic_suspended_solids;
                                          concept_inorganic_suspended_solids;;

concept_inorganic_suspended_solids <- sc_node_class;
                                 => nrel_main_idtf: [неорганические: песок, глина, ржавчина](*<- lang_ru;;*);;
                                 
concept_organic_suspended_solids <- sc_node_class;
                                 => nrel_main_idtf: [органические: остатки растений, бактерии](*<- lang_ru;;*);;                                 

concept_suspended_solids => nrel_application:
                                            concept_wastewater_treatment;
                                            concept_water_quality_monitoring;;

concept_suspended_solids => nrel_technical_parameter:
    rrel_concentration;
    rrel_particle_size;;

    rrel_concentration <- sc_node_role_relation; 
    => nrel_main_idtf: [мг/л](*<- lang_ru;;*);;

    rrel_particle_size <- sc_node_role_relation; 
    => nrel_main_idtf: [мкм](*<- lang_ru;;*);;

concept_suspended_solids => nrel_operation_principle:
                                            concept_sedimentation;
                                            concept_filtration;
                                            concept_coagulation;;

    concept_wastewater_treatment <- sc_node_class; 
    => nrel_main_idtf: [очистка сточных вод](*<- lang_ru;;*);;
    concept_water_quality_monitoring <- sc_node_class; 
    => nrel_main_idtf: [мониторинг качества воды](*<- lang_ru;;*);;

    concept_sedimentation <- sc_node_class;
    => nrel_main_idtf: [осаждение](*<- lang_ru;;*);;
    concept_filtration <- sc_node_class;
    => nrel_main_idtf: [фильтрация](*<- lang_ru;;*);;
    concept_coagulation <- sc_node_class;
    => nrel_main_idtf: [коагуляция](*<- lang_ru;;*);;





concept_biochemical_oxygen_demand <- sc_node_class;
    => nrel_main_idtf: [биохимическое потребление кислорода (БПК₅)](*<- lang_ru;;*);
    => sc_link_content: [количество кислорода, необходимое для биохимического окисления органических веществ микроорганизмами в воде в течение 5 суток при температуре 20°с.];;
concept_biochemical_oxygen_demand -> rrel_maximum_studied_object_class: concept_major_pollutants;;
concept_biochemical_oxygen_demand => nrel_partition:
    concept_BOD_total;
    concept_BOD_5;
    concept_BOD_1;;

concept_biochemical_oxygen_demand => nrel_application:
    concept_wastewater_quality_control;
    concept_treatment_efficiency_evaluation;
    concept_pollution_assessment;
    concept_aeration_calculation;;

concept_biochemical_oxygen_demand => nrel_technical_parameter:
    rrel_unit;
    rrel_standard_duration;
    rrel_dependency_factors;;

concept_biochemical_oxygen_demand => nrel_operation_principle:
    concept_oxidation_by_microorganisms;
    concept_oxygen_consumption;
    concept_dissolved_oxygen_drop;;

concept_biochemical_oxygen_demand => nrel_component:
    concept_organic_pollutants;
    concept_aerobic_microorganisms;
    concept_dissolved_oxygen;;

concept_biochemical_oxygen_demand => nrel_type:
    concept_BOD_total_type;
    concept_BOD_5_type;
    concept_BOD_1_type;;

concept_BOD_total <- sc_node_class;
    => nrel_main_idtf: [БПК полного окисления (БПК∞)](*<- lang_ru;;*);;

concept_BOD_5 <- sc_node_class;
    => nrel_main_idtf: [БПК₅ — стандартное измерение за 5 суток](*<- lang_ru;;*);;

concept_BOD_1 <- sc_node_class;
    => nrel_main_idtf: [БПК₁ — краткосрочное измерение](*<- lang_ru;;*);;


